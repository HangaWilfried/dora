    "dayjs": "^1.11.20",
    "jwt-decode": "^4.0.0",
    "lucide-vue-next": "^0.539.0",
    "notivue": "^2.4.5",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.2",
    "tailwindcss": "^4.2.1",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.29",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.3",
